# NFT Sale & Mint Notification Bot - Environment Variables
# Copy this file to .env and fill in your values
# See README.md for detailed setup instructions

# ─── REQUIRED: Database ────────────────────────────────────────────────────────
# PostgreSQL connection string (e.g. from Railway, Supabase, Neon, etc.)
DATABASE_URL=postgresql://user:password@host:port/database

# ─── REQUIRED: SentX API ───────────────────────────────────────────────────────
# Get your API key from https://sentx.io → User Settings
SENTX_API_KEY=your_sentx_api_key_here

# ─── REQUIRED: Twitter API v2 ──────────────────────────────────────────────────
# Get credentials from https://developer.twitter.com/en/portal/dashboard
# Requires Elevated access (to upload media) and Read + Write permissions
TWITTER_BEARER_TOKEN=your_bearer_token_here
TWITTER_CONSUMER_KEY=your_consumer_key_here
TWITTER_CONSUMER_SECRET=your_consumer_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ─── REQUIRED: NFT Collection ──────────────────────────────────────────────────
# Hedera token ID for your NFT collection (format: 0.0.XXXXXXX)
COLLECTION_ID=0.0.6024491

# Human-readable name for your collection (used in tweets)
COLLECTION_NAME=Wild Tigers

# URL slug used on SentX marketplace (the part after /nft-marketplace/)
SENTX_COLLECTION_SLUG=wild-tigers

# Total NFT supply in your collection (used for rarity tier calculations)
TOTAL_SUPPLY=3332

# ─── OPTIONAL: Collection Branding ─────────────────────────────────────────────
# Your collection's website (shown at the end of tweets — leave blank to omit)
COLLECTION_WEBSITE=WildTigers.World

# ─── OPTIONAL: Bot Tuning ──────────────────────────────────────────────────────
# How often (in seconds) to poll SentX for new activity (default: 30)
POLL_INTERVAL=30
